# Resend — email sending
RESEND_API_KEY=re_xxxx

# Stripe — payment link (created by Founder)
STRIPE_PAYMENT_LINK=https://buy.stripe.com/xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# GA4
GA4_MEASUREMENT_ID=G-xxxx

# Email sender (must be a verified Resend domain)
FROM_EMAIL=noreply@useritmo.pt

# Vercel KV — free-tier quota enforcement (1 calc/month per email)
# Create a KV store in Vercel dashboard → Storage → KV, then link to this project.
# Linking auto-populates these env vars in production and preview.
KV_REST_API_URL=https://xxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxx
